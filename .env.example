# Contact form (src/app/api/contact/route.js) — sends submissions via Resend.
# Copy this file to .env.local and fill in the real values; .env.local is
# gitignored and never committed.

# Get a key at https://resend.com/api-keys (free tier covers a portfolio
# contact form). Without this set, the API route logs the submission
# server-side and returns a clear "not configured" error to the form.
RESEND_API_KEY=

# Where submissions are delivered. Defaults to worapit.m@gmail.com if unset.
CONTACT_TO_EMAIL=worapit.m@gmail.com

# The "from" address Resend sends as. Until a custom domain is verified
# with Resend, use their shared sandbox sender below.
CONTACT_FROM_EMAIL=onboarding@resend.dev
